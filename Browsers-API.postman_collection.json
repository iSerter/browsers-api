		{
			"name": "API Keys",
			"item": [
				{
					"name": "Create API Key",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201 || pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    const data = jsonData.data || jsonData;",
									"    if (data.key) {",
									"        pm.collectionVariables.set(\"apiKey\", data.key);",
									"        pm.collectionVariables.set(\"apiKeyId\", data.id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Admin-Password",
								"value": "{{adminPassword}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"clientId\": \"my-client-id\",\n  \"name\": \"My API Key\",\n  \"rateLimit\": 100,\n  \"expiresAt\": null\n}",
							"options": {
